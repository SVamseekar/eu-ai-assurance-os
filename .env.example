# =============================================================================
# EU AI Assurance OS — environment template (Part 9)
# Copy to repo root as `.env` for Docker Compose, or export in your shell.
# NEVER commit real secrets. See docs/DEPLOYMENT.md and docs/NFR.md.
# =============================================================================

# --- Core API secrets (required in shared / production environments) ---
# HMAC secret for eval result callbacks (X-Eval-Signature). Empty is OK for local H2 only.
EVAL_CALLBACK_SECRET=local-dev-eval-callback-secret-change-me

# Hash-chain HMAC for append-only audit (Part 6). Default exists only for local dev.
AUDIT_CHAIN_SECRET=local-dev-audit-chain-secret-change-me

# --- Database (Compose postgres service + API postgres profile) ---
POSTGRES_DB=eu_ai_assurance
POSTGRES_USER=eu_ai_assurance
POSTGRES_PASSWORD=eu_ai_assurance

# JDBC URL used by the API container (host `postgres` is the Compose service name)
DATABASE_URL=jdbc:postgresql://postgres:5432/eu_ai_assurance
DATABASE_USERNAME=eu_ai_assurance
DATABASE_PASSWORD=eu_ai_assurance

# --- Dashboard (BFF → API) ---
# Browser-facing origin for the Next.js app (SEO, cookies). Local: http://localhost:3000
ASSURANCE_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional GA4 measurement id (leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public marketing / ops placeholders (optional)
DISCORD_INVITE_URL=
DISCORD_WEBHOOK_URL=
# Server-side only; never NEXT_PUBLIC_
DISCORD_BOT_TOKEN=

# --- OAuth / OIDC placeholders (Part 4 — not wired yet) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Evidence embeddings ---
# Compose default: local-hash (fast, no model download). For DJL/ONNX all-MiniLM-L6-v2
# set djl-sentence (needs outbound HTTPS to Hugging Face on first boot; allow 1–2GB RAM).
# Postgres profile app default remains djl-sentence when this var is unset outside Compose.
EVIDENCE_EMBEDDING_PROVIDER=local-hash

# --- Optional S3-compatible object store (MinIO profile or real S3) ---
ASSURANCE_STORAGE_ENABLED=false
ASSURANCE_STORAGE_BUCKET=eu-ai-assurance-evidence
ASSURANCE_STORAGE_REGION=eu-west-1
# Custom endpoint for MinIO (Compose): http://minio:9000
ASSURANCE_STORAGE_ENDPOINT=
ASSURANCE_STORAGE_ACCESS_KEY_ID=
ASSURANCE_STORAGE_SECRET_ACCESS_KEY=
# When true (default if endpoint set), use path-style URLs required by MinIO
ASSURANCE_STORAGE_PATH_STYLE=true

# MinIO root credentials (Compose profile: minio)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- CI release gate bots (see docs/OPS.md) ---
ASSURANCE_API_BASE=http://localhost:8080
ASSURANCE_API_KEY=
SYSTEM_ID=

# --- Spring ---
SPRING_PROFILES_ACTIVE=postgres
