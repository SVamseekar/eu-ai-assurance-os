# Copy to terraform.tfvars locally (gitignored if you add the pattern).
# Never put real cloud credentials or secret values here.

project_name  = "eu-ai-assurance"
environment   = "dev"
region        = "eu-west-1"

db_instance_class = "db.t4g.medium"
api_cpu           = "1"
api_memory        = "2Gi"

enable_object_storage = true

tags = {
  app         = "eu-ai-assurance-os"
  environment = "dev"
  managed     = "terraform-skeleton"
}
